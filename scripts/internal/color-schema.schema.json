{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Color Scheme",
  "description": "Schema for validating color scheme YAML files for GDSII layer visualization",
  "type": "object",
  "required": ["name", "description", "layers"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the color scheme"
    },
    "description": {
      "type": "string",
      "description": "Description of the color scheme"
    },
    "materials": {
      "type": "object",
      "description": "Named Blender material definitions",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "$ref": "#/definitions/material"
        }
      },
      "additionalProperties": false
    },
    "layers": {
      "type": "object",
      "description": "Layer definitions. Each layer may either reference a named material or define one inline.",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "oneOf": [
            {
              "type": "string",
              "description": "Reference to a named material."
            },
            {"$ref": "#/definitions/material"}
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "material": {
      "type": "object",
      "description": "A Blender material definition consisting of arbitrary Principled BSDF inputs or material properties.",
      "patternProperties": {
        "^.+$": {
          "$ref": "#/definitions/materialProperty"
        }
      },
      "additionalProperties": false
    },
    "materialProperty": {
      "description": "A Blender material property value.",
      "oneOf": [
        {"type": "number"},
        {"type": "boolean"},
        {"type": "string"},
        {
          "type": "array",
          "description": "RGB or RGBA color.",
          "minItems": 3,
          "maxItems": 4,
          "items": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      ]
    }
  },
  "additionalProperties": false
}